<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher_ug"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_ug_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MoodleUG"
        android:usesCleartextTraffic="true">
        <!-- 1. El Splash Screen AHORA es la actividad principal -->
        <activity
            android:name=".ui.login.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.grades.GradesActivity"
            android:exported="false" />
        <activity
            android:name=".ui.courses.ForumReplyActivity"
            android:exported="false" />
        <activity
            android:name=".ui.courses.ForumActivity"
            android:exported="false" />
        <activity
            android:name=".ui.courses.AssignmentActivity"
            android:exported="false" />
        <activity
            android:name=".ui.courses.CourseDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ui.courses.CoursesActivity"
            android:exported="false" />
        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar">
        </activity>
    </application>

</manifest>